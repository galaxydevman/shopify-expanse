{%- doc -%}
  Copyright © 2025 Archetype Themes LP. All rights reserved.

  Renders a horizontally scrolling list of collection cards.
  Shows 8 collections at once on desktop in a single row, with
  centered left/right arrow buttons that move one collection at a time.
{%- enddoc -%}

{%- liquid
  assign hydration = hydration | default: 'on:idle'
-%}

<is-land {{ hydration }}>
  <featured-collections-component
    class="layout-section layout-section--featured-collections"
    section-id="{{ section.id }}"
  >
    {%- capture inner -%}
      {%- render 'layout.section-heading', url: routes.collections_url -%}

      {%- if section.blocks.size > 0 -%}
        <div class="featured-collections__slider-wrapper">
          <div
            class="featured-collections__slider"
            id="FeaturedCollections-{{ section.id }}"
            data-visible-desktop="8"
            data-visible-mobile="2"
            data-count="{{ section.blocks.size }}"
            data-arrows="true"
          >
            {%- for block in section.blocks -%}
              <div
                class="featured-collections__slide slideshow__slide featured-collections__slide--{{ block.id }}"
                data-index="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                <div class="featured-collections__slide-inner">
                  {%- render 'list.collection-card',
                    block: block,
                    collection: block.settings.collection,
                    sizeVariable: sizeVariable,
                    fallback: 'variable'
                  -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        {%- render 'utility.translate',
          key: 'info.section_no_content',
          fallback: "This section doesn't currently include any content. Add content to this section using the sidebar."
        -%}
      {%- endif -%}
    {%- endcapture -%}

    {%- render 'layout.section', slot: inner -%}
  </featured-collections-component>

  <template data-island>
    <script type="module">
      import 'section.featured-collections'
    </script>
  </template>
</is-land>

{%- stylesheet -%}
  .layout-section--featured-collections {
    overflow: hidden;
  }

  .featured-collections__slider-wrapper {
    position: relative;
    width: 80%;
    margin-left: auto;
    margin-right: auto;
  }

  .featured-collections__slider {
    width: 100%;
  }

  .featured-collections__slide {
    /* Default: mobile */
    width: 50%;
    padding: 0 6px;
    box-sizing: border-box;
  }

  .featured-collections__slide-inner {
    width: 66%;
    margin: 0 auto;
  }

  @media only screen and (min-width: 769px) {
    .featured-collections__slide {
      /* 8 items visible in one row on desktop */
      width: 12.5%;
      padding: 0 8px;
    }

    .featured-collections__slide-inner {
      width: 66%;
    }
  }

  /* Keep carousel height tight around each collection card */
  .layout-section--featured-collections .slideshow__slide {
    padding-bottom: 0;
    margin-bottom: 0;
  }

  /* Remove extra spacing from legacy grid styles applied inside cards */
  .layout-section--featured-collections .grid-item {
    padding: 0;
    margin: 0;
  }
{%- endstylesheet -%}
