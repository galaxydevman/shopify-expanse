{%- comment -%}
  Renders a full-width page section with its title and content.

  Accepts:
  - page {page} - The page object

  Usage:
  {% render 'section.main-page-full-width' %}
{%- endcomment -%}

<div class="page-full page-content">
  <header class="section-header">
    <h1 class="section-header__title">
      {{ page.title | escape }}
    </h1>
  </header>

  {%- render 'element.text', text: page.content, variant: 'rte' -%}
</div>
