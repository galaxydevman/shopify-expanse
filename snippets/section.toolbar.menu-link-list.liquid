{%- comment -%}
  Renders a list of links

  Accepts:
  - menu_link_list {linklist} - The list of links to render
  - wrapper_class {string} - The class to apply to the wrapper

  Usage:
  {% render 'section.toolbar.menu-link-list' %}
{%- endcomment -%}

{% stylesheet %}
	.menu-link-list {
	  display: flex;
	  flex-wrap: wrap;
	  gap: 20px;
	  margin: 0;
	}
	
	.menu-link-list__item {
	  margin: 0;
	
	  a {
	    padding-top: 0.375rem;
	    padding-bottom: 0.375rem;
	  }
	}
{% endstylesheet %}

{%- liquid
  assign menu_link_list = menu_link_list | default: section.settings.menu_link_list
  assign wrapper_class = wrapper_class | default: blank
%}

{% if menu_link_list != blank %}
  <ul class="menu-link-list{% if wrapper_class != blank %} {{ wrapper_class }}{% endif %}">
    {% for link in menu_link_list.links %}
      <li class="menu-link-list__item">
        <a href="{{ link.url }}" class="menu-link-list__link">{{ link.title }}</a>
      </li>
    {% endfor %}
  </ul>
{% endif %}