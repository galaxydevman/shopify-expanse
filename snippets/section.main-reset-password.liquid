{%- comment -%}
  Renders the customer reset password section.

  Usage:
  {% render 'section.main-reset-password %}
{%- endcomment -%}

{%- capture input_password_label -%}
  {% render 'utility.translate', key: 'labels.password', fallback: 'Password' -%}
{%- endcapture -%}

{%- capture input_password_confirmation_label -%}
  {% render 'utility.translate', key: 'actions.confirm_password', fallback: 'Confirm password' -%}
{%- endcapture -%}

{%- capture input_reset_password_label -%}
  {% render 'utility.translate', key: 'actions.reset_password', fallback: 'Reset password' -%}
{%- endcapture -%}

<div class="page-width page-width--tiny page-content">
  <div class="form-vertical">
    {%- form 'reset_customer_password' -%}
      <header class="section-header">
        <h1 class="section-header__title">
          {% render 'utility.translate', key: 'actions.reset_account_password', fallback: 'Reset account password' %}
        </h1>
        <p>
          {% assign actions_enter_new_password = 'actions.enter_new_password' | t: email: email %}
          {%- capture fallback_actions_enter_new_password -%}
            Enter a new password for {{ email }}
          {%- endcapture -%}
          {% render 'utility.translate', t: actions_enter_new_password, fallback: fallback_actions_enter_new_password %}
        </p>
      </header>

      {{ form.errors | default_errors }}

      {%- render 'element.input',
        type: 'password',
        id: 'ResetPassword',
        name: 'customer[password]',
        placeholder: input_password_label
      -%}

      {%- render 'element.input',
        type: 'password',
        id: 'PasswordConfirmation',
        name: 'customer[password_confirmation]',
        placeholder: input_password_confirmation_label
      -%}

      <div class="text-center">
        {%- render 'element.button',
          type: 'submit',
          id: 'reset-password-submit',
          text: input_reset_password_label,
          full: true
        -%}
      </div>
    {%- endform -%}
  </div>
</div>
