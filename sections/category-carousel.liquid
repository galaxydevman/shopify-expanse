{%- liquid
  assign section_title        = section.settings.title
  assign section_width        = section.settings.section_width        | default: 100
  assign mobile_section_width = section.settings.mobile_section_width | default: 100
  assign shape                = section.settings.shape               | default: 'circle'
  assign border_style         = section.settings.border_style        | default: 'none'
  assign image_width          = section.settings.image_width         | default: 96
  assign image_height         = section.settings.image_height        | default: 96
  assign item_gap             = section.settings.item_gap            | default: 16
  assign content_position     = section.settings.content_position    | default: 'center'
  assign padding_top          = section.settings.padding_top         | default: 40
  assign padding_bottom       = section.settings.padding_bottom      | default: 40
  assign padding_left         = section.settings.padding_left        | default: 20
  assign padding_right        = section.settings.padding_right       | default: 20
  assign show_labels          = section.settings.show_labels
  assign autoplay             = section.settings.autoplay
  assign autoplay_speed       = section.settings.autoplay_speed      | default: 3
  assign bg_color             = section.settings.bg_color
  assign arrow_color          = section.settings.arrow_color
  assign label_color          = section.settings.label_color
  assign title_font_size      = section.settings.title_font_size     | default: 22
  assign title_font_weight    = section.settings.title_font_weight   | default: '700'
  assign title_font_style     = section.settings.title_font_style    | default: 'normal'
  assign title_font_family    = section.settings.title_font_family   | default: 'inherit'
  assign label_font_size      = section.settings.label_font_size     | default: 12
  assign label_font_weight    = section.settings.label_font_weight   | default: '600'
  assign label_font_style     = section.settings.label_font_style    | default: 'normal'
  assign label_text_transform = section.settings.label_text_transform | default: 'none'
  assign label_font_family    = section.settings.label_font_family   | default: 'inherit'

  assign mobile_image_width    = section.settings.mobile_image_width    | default: 56
  assign mobile_image_height   = section.settings.mobile_image_height   | default: 56
  assign mobile_item_gap       = section.settings.mobile_item_gap       | default: 12
  assign mobile_padding_top    = section.settings.mobile_padding_top    | default: 20
  assign mobile_padding_bottom = section.settings.mobile_padding_bottom | default: 20
  assign mobile_padding_left   = section.settings.mobile_padding_left   | default: 12
  assign mobile_padding_right  = section.settings.mobile_padding_right  | default: 12

-%}

{%- comment -%}Only color vars stay inline — spacing vars live in the <style> block so mobile @media can override them.{%- endcomment -%}
{%- capture css_vars -%}
  {%- unless bg_color == blank or bg_color == 'rgba(0,0,0,0)' -%}--cc-bg: {{ bg_color }};{%- endunless -%}
  {%- unless arrow_color == blank or arrow_color == 'rgba(0,0,0,0)' -%}--cc-arrow: {{ arrow_color }};{%- endunless -%}
  {%- unless label_color == blank or label_color == 'rgba(0,0,0,0)' -%}--cc-label: {{ label_color }};{%- endunless -%}
{%- endcapture -%}

<section
  id="cc-{{ section.id }}"
  class="cc-section cc-shape--{{ shape }} cc-border--{{ border_style }} cc-pos--{{ content_position }}"
  style="{{ css_vars | strip_newlines }}"
>
  {%- if section_title != blank -%}
    <h2 class="cc-heading">{{ section_title | escape }}</h2>
  {%- endif -%}

  <div class="cc-outer">
    <button class="cc-arrow cc-arrow--prev" aria-label="Previous" disabled>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    <div class="cc-track-wrapper">
      <div class="cc-track" id="cc-track-{{ section.id }}">

        {%- for block in section.blocks -%}
            {%- liquid
              assign col         = block.settings.collection
              assign cust_img    = block.settings.custom_image
              assign cust_title  = block.settings.custom_title
              assign img_fit     = block.settings.image_fit    | default: 'cover'
              assign image_scale = block.settings.image_scale | default: 100
              assign item_bg     = block.settings.item_bg_color
              assign badge_text  = block.settings.badge_text
              assign badge_color = block.settings.badge_color

              if cust_title != blank
                assign label = cust_title
              elsif col != blank
                assign label = col.title
              else
                assign label = 'Collection'
              endif

              if col != blank
                assign col_url = col.url
              else
                assign col_url = '#'
              endif

              if cust_img != blank
                assign img = cust_img
              elsif col != blank and col.image != blank
                assign img = col.image
              elsif col != blank and col.products.first != blank
                assign img = col.products.first.featured_media.preview_image
              else
                assign img = blank
              endif
            -%}

            {%- capture item_style -%}
              {%- unless item_bg == blank or item_bg == 'rgba(0,0,0,0)' -%}--cc-item-bg:{{ item_bg }};{%- endunless -%}
              {%- if image_scale != 100 -%}--cc-img-scale:{{ image_scale }};{%- endif -%}
            {%- endcapture -%}
            <div
              class="cc-item"
              data-url="{{ col_url }}"
              data-scale="{{ image_scale }}"
              {{ block.shopify_attributes }}
              {%- unless item_style == blank -%}style="{{ item_style | strip }}" {%- endunless -%}
            >
              <a href="{{ col_url }}" class="cc-item-link">
                <div class="cc-img-frame">
                  <div class="cc-img-wrap">
                    {%- if img != blank -%}
                      <img
                        src="{{ img | image_url: width: 300 }}"
                        alt="{{ label | escape }}"
                        loading="lazy"
                        width="300"
                        height="300"
                        class="cc-img cc-fit--{{ img_fit }}"
                      >
                    {%- else -%}
                      <div class="cc-img-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                          <circle cx="8.5" cy="8.5" r="1.5"/>
                          <polyline points="21 15 16 10 5 21"/>
                        </svg>
                      </div>
                    {%- endif -%}
                  </div>

                  {%- if badge_text != blank -%}
                    <span
                      class="cc-badge"
                      {%- unless badge_color == blank or badge_color == 'rgba(0,0,0,0)' -%}
                        style="background:{{ badge_color }};"
                      {%- endunless -%}
                    >{{ badge_text | escape }}</span>
                  {%- endif -%}
                </div>

                {%- if show_labels -%}
                  <span class="cc-label">{{ label | escape }}</span>
                {%- endif -%}
              </a>
            </div>
        {%- endfor -%}

      </div>
    </div>

    <button class="cc-arrow cc-arrow--next" aria-label="Next">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>
</section>

<style>
  /* ── Root variables & spacing ───────────────────────────────────── */
  #cc-{{ section.id }} {
    --cc-gap:     {{ item_gap }}px;
    --cc-pt:      {{ padding_top }}px;
    --cc-pb:      {{ padding_bottom }}px;
    --cc-pl:      {{ padding_left }}px;
    --cc-pr:      {{ padding_right }}px;
    --cc-bg:      transparent;
    --cc-arrow:   #444;
    --cc-label:   #333;
    --cc-item-bg: #f0f2f5;
    --cc-img-w:   {{ image_width }}px;
    --cc-img-h:   {{ image_height }}px;

    max-width:        {{ section_width }}%;
    margin-left:      auto;
    margin-right:     auto;
    padding-top:      var(--cc-pt);
    padding-bottom:   var(--cc-pb);
    padding-left:     var(--cc-pl);
    padding-right:    var(--cc-pr);
    background-color: var(--cc-bg);
    box-sizing:       border-box;
    overflow:         hidden;
  }

  /* ── Heading ────────────────────────────────────────────────────── */
  #cc-{{ section.id }} .cc-heading {
    margin:          0 0 20px;
    font-size:       {{ title_font_size }}px;
    font-weight:     {{ title_font_weight }};
    font-style:      {{ title_font_style }};
    font-family:     {{ title_font_family }};
    color:           var(--cc-label);
  }

  /* ── Content position ───────────────────────────────────────────── */
  #cc-{{ section.id }}.cc-pos--left   .cc-heading { text-align: left;   }
  #cc-{{ section.id }}.cc-pos--center .cc-heading { text-align: center; }
  #cc-{{ section.id }}.cc-pos--right  .cc-heading { text-align: right;  }

  /* ── Layout shell ───────────────────────────────────────────────── */
  #cc-{{ section.id }} .cc-outer {
    display:     flex;
    align-items: center;
    gap:         8px;
  }

  #cc-{{ section.id }} .cc-track-wrapper {
    flex:     1;
    overflow: hidden;
    cursor:   grab;
    /* vertical padding gives the shadow room to render without being clipped */
    padding-top:    20px;
    padding-bottom: 20px;
    margin-top:    -20px;
    margin-bottom: -20px;
  }

  #cc-{{ section.id }} .cc-track {
    display:     flex;
    gap:         var(--cc-gap);
    transform:   translateX(0);
    transition:  transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* ── Arrows ─────────────────────────────────────────────────────── */
  #cc-{{ section.id }} .cc-arrow {
    flex-shrink:     0;
    display:         flex;
    align-items:     center;
    justify-content: center;
    width:           40px;
    height:          40px;
    border-radius:   50%;
    border:          1.5px solid #e0e0e0;
    background:      #fff;
    cursor:          pointer;
    color:           var(--cc-arrow);
    box-shadow:      0 1px 4px rgba(0,0,0,.08);
    transition:      opacity 0.2s, background 0.2s, box-shadow 0.2s;
  }

  #cc-{{ section.id }} .cc-arrow svg { width: 18px; height: 18px; }

  #cc-{{ section.id }} .cc-arrow[disabled] {
    opacity:        0.3;
    cursor:         default;
    pointer-events: none;
  }

  #cc-{{ section.id }} .cc-arrow:not([disabled]):hover {
    background: #f5f5f5;
    box-shadow: 0 3px 10px rgba(0,0,0,.12);
  }

  /* ── Item ───────────────────────────────────────────────────────── */
  #cc-{{ section.id }} .cc-item {
    flex-shrink: 0;
    text-align:  center;
    padding:     0 6px; /* outer gap around each circle */
  }

  #cc-{{ section.id }} .cc-item-link {
    display:         flex;
    flex-direction:  column;
    align-items:     center;
    text-decoration: none;
    color:           inherit;
    outline:         none;
  }

  /* Frame wraps the circle + badge without clipping */
  #cc-{{ section.id }} .cc-img-frame {
    position: relative;
    display:  inline-block;
  }

  #cc-{{ section.id }} .cc-img-wrap {
    width:  var(--cc-img-w);
    height: var(--cc-img-h);
    position:         relative;
    background-color: var(--cc-item-bg);
    overflow:         hidden;
    cursor:           zoom-in;
    /* translateZ(0) forces a GPU compositing layer so border-radius
       correctly clips absolutely-positioned children in all browsers */
    transform:        translateZ(0);
    transition:       width 0.3s ease, height 0.3s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  #cc-{{ section.id }} .cc-img-wrap.cc-zoomed { cursor: zoom-out; }

  /* Shapes */
  #cc-{{ section.id }}.cc-shape--circle  .cc-img-wrap { border-radius: 50%;  }
  #cc-{{ section.id }}.cc-shape--square  .cc-img-wrap { border-radius: 6px;  }
  #cc-{{ section.id }}.cc-shape--rounded .cc-img-wrap { border-radius: 20px; }

  /* Border styles */
  #cc-{{ section.id }}.cc-border--thin   .cc-img-wrap { border: 1px solid #e0e0e0;          }
  #cc-{{ section.id }}.cc-border--medium .cc-img-wrap { border: 2.5px solid #c8c8c8;         }
  #cc-{{ section.id }}.cc-border--shadow .cc-img-wrap { box-shadow: 0 3px 14px rgba(0,0,0,.13); }

  /* ── Image ──────────────────────────────────────────────────────── */
  #cc-{{ section.id }} .cc-img {
    position:         absolute;
    inset:            0;
    width:            100%;
    height:           100%;
    transform-origin: center center;
    /* --cc-img-scale set per-block (default 100 = no change) */
    transform:        scale(calc(var(--cc-img-scale, 100) / 100));
  }

  #cc-{{ section.id }} .cc-fit--cover   .cc-img { object-fit: cover;   }
  #cc-{{ section.id }} .cc-fit--contain .cc-img { object-fit: contain; }

  #cc-{{ section.id }} .cc-img-placeholder {
    position:        absolute;
    inset:           0;
    display:         flex;
    align-items:     center;
    justify-content: center;
    color:           #ccc;
  }

  #cc-{{ section.id }} .cc-img-placeholder svg { width: 50%; height: 50%; }

  /* ── Hover lift ─────────────────────────────────────────────────── */
  #cc-{{ section.id }} .cc-item:hover .cc-img-wrap {
    transform:  translateZ(0) translateY(-4px);
    box-shadow: 0 6px 14px rgba(0,0,0,.18);
  }

  /* ── Active ring (current collection page) ──────────────────────── */
  #cc-{{ section.id }} .cc-item.cc-active .cc-img-wrap {
    box-shadow: 0 0 0 3px currentColor, 0 0 0 5px #fff;
  }

  /* ── Badge ──────────────────────────────────────────────────────── */
  #cc-{{ section.id }} .cc-badge {
    position:       absolute;
    top:            6px;
    right:          6px;
    background:     #e44;
    color:          #fff;
    font-size:      9px;
    font-weight:    800;
    padding:        2px 6px;
    border-radius:  20px;
    line-height:    1.5;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    z-index:        2;
    white-space:    nowrap;
  }

  /* ── Label ──────────────────────────────────────────────────────── */
  #cc-{{ section.id }} .cc-label {
    display:        block;
    margin-top:     10px;
    font-size:      {{ label_font_size }}px;
    font-weight:    {{ label_font_weight }};
    font-style:     {{ label_font_style }};
    text-transform: {{ label_text_transform }};
    font-family:    {{ label_font_family }};
    color:          var(--cc-label);
    max-width:      110px;
    line-height:    1.3;
    word-break:     break-word;
  }

  /* ── Mobile (≤ 768px): native swipe + visible arrows ────────────── */
  @media (max-width: 768px) {
    #cc-{{ section.id }} {
      max-width: {{ mobile_section_width }}%;
      --cc-gap: {{ mobile_item_gap }}px;
      --cc-pt:  {{ mobile_padding_top }}px;
      --cc-pb:  {{ mobile_padding_bottom }}px;
      --cc-pl:  {{ mobile_padding_left }}px;
      --cc-pr:  {{ mobile_padding_right }}px;
      --cc-img-w: {{ mobile_image_width }}px;
      --cc-img-h: {{ mobile_image_height }}px;
    }

    #cc-{{ section.id }} .cc-arrow {
      width:  32px;
      height: 32px;
    }
    #cc-{{ section.id }} .cc-arrow svg { width: 14px; height: 14px; }

    #cc-{{ section.id }} .cc-track-wrapper {
      overflow-x:                 auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width:            none;
      /* overflow-x:auto forces overflow-y:auto too, which clips content above y=0.
         padding-top gives the badge (top:-4px) room to render without being cut. */
      padding-top:    10px;
      padding-bottom: 10px;
    }

    #cc-{{ section.id }} .cc-track-wrapper::-webkit-scrollbar { display: none; }

    #cc-{{ section.id }} .cc-track {
      transform:  none !important;
      transition: none !important;
    }
  }
</style>

<script>
(function () {
  var root = document.getElementById('cc-{{ section.id }}');
  if (!root) return;

  var track   = root.querySelector('.cc-track');
  var wrapper = root.querySelector('.cc-track-wrapper');
  var prev    = root.querySelector('.cc-arrow--prev');
  var next    = root.querySelector('.cc-arrow--next');
  if (!track || !wrapper || !prev || !next) return;

  /* ── Carousel scroll ──────────────────────────────────────────── */
  var offset = 0;

  /* Mark active item by matching href to current pathname */
  track.querySelectorAll('.cc-item').forEach(function (item) {
    var link = item.querySelector('a');
    if (link && link.getAttribute('href') === window.location.pathname) {
      item.classList.add('cc-active');
    }
  });

  function isMobile()      { return window.innerWidth <= 768; }
  function maxOffset()     { return Math.max(0, track.scrollWidth - wrapper.offsetWidth); }
  function maxScrollLeft() { return Math.max(0, wrapper.scrollWidth - wrapper.clientWidth); }

  function stepSize() {
    var first = track.querySelector('.cc-item');
    if (!first) return 0;
    return first.offsetWidth + (parseFloat(getComputedStyle(track).gap) || 0);
  }

  function updateArrows() {
    if (isMobile()) {
      var s = wrapper.scrollLeft;
      prev.disabled = s <= 1;
      next.disabled = s >= maxScrollLeft() - 1;
    } else {
      prev.disabled = offset <= 0;
      next.disabled = offset >= maxOffset();
    }
  }

  function goTo(newOffset) {
    offset = Math.min(Math.max(newOffset, 0), maxOffset());
    track.style.transform = 'translateX(-' + offset + 'px)';
    updateArrows();
  }

  prev.addEventListener('click', function () {
    if (isMobile()) {
      wrapper.scrollBy({ left: -stepSize(), behavior: 'smooth' });
      setTimeout(updateArrows, 400);
    } else {
      goTo(offset - stepSize());
    }
  });

  next.addEventListener('click', function () {
    if (isMobile()) {
      wrapper.scrollBy({ left: stepSize(), behavior: 'smooth' });
      setTimeout(updateArrows, 400);
    } else {
      goTo(offset + stepSize());
    }
  });

  /* Keep arrow state in sync with native mobile scroll */
  wrapper.addEventListener('scroll', function () {
    if (isMobile()) updateArrows();
  }, { passive: true });

  /* ── Touch swipe (desktop touch screens) ─────────────────────────── */
  var swipeX = 0;
  track.addEventListener('touchstart', function (e) { swipeX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend',   function (e) {
    if (isMobile()) return;
    var diff = swipeX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(offset + (diff > 0 ? stepSize() : -stepSize()));
  }, { passive: true });

  /* ── Mouse drag (desktop) ─────────────────────────────────────────── */
  var dragStartX   = 0;
  var dragStartOff = 0;
  var isDragging   = false;
  var dragMoved    = false;

  wrapper.addEventListener('mousedown', function (e) {
    if (isMobile()) return;
    isDragging   = true;
    dragMoved    = false;
    dragStartX   = e.clientX;
    dragStartOff = offset;
    wrapper.style.cursor = 'grabbing';
    track.style.transition = 'none'; /* disable smooth anim while dragging */
    e.preventDefault();
  });

  window.addEventListener('mousemove', function (e) {
    if (!isDragging) return;
    var delta = dragStartX - e.clientX;
    if (Math.abs(delta) > 4) dragMoved = true;
    var newOffset = Math.min(Math.max(dragStartOff + delta, 0), maxOffset());
    offset = newOffset;
    track.style.transform = 'translateX(-' + offset + 'px)';
    updateArrows();
  });

  window.addEventListener('mouseup', function () {
    if (!isDragging) return;
    isDragging = false;
    wrapper.style.cursor = '';
    track.style.transition = ''; /* restore smooth transition */
  });

  /* Prevent link navigation if the user dragged rather than clicked */
  wrapper.addEventListener('click', function (e) {
    if (dragMoved) {
      e.preventDefault();
      dragMoved = false;
    }
  }, true);

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () { if (!isMobile()) goTo(offset); updateArrows(); }, 100);
  });

  updateArrows();

  /* ── Autoplay ─────────────────────────────────────────────────── */
  var autoplayEnabled = {{ autoplay | json }};
  var autoplaySpeed   = {{ autoplay_speed | times: 1000 }};

  if (autoplayEnabled) {
    var autoTimer = null;
    var paused    = false;

    function autoStep() {
      if (paused || isMobile()) return;
      var max = maxOffset();
      /* Loop back to start when the last item is reached */
      if (max <= 0 || offset >= max) {
        offset = 0;
        track.style.transform = 'translateX(0)';
        updateArrows();
      } else {
        goTo(offset + stepSize());
      }
    }

    function startAuto() { autoTimer = setInterval(autoStep, autoplaySpeed); }
    function stopAuto()  { clearInterval(autoTimer); }

    startAuto();

    root.addEventListener('mouseenter', function () { paused = true;  stopAuto();  });
    root.addEventListener('mouseleave', function () { paused = false; startAuto(); });
    root.addEventListener('touchstart', function () { paused = true;  stopAuto();  }, { passive: true });
    root.addEventListener('touchend',   function () {
      paused = false;
      setTimeout(startAuto, autoplaySpeed);
    }, { passive: true });
  }

  /* ── Scroll-to-zoom on each image ─────────────────────────────── */
  track.querySelectorAll('.cc-item').forEach(function (item) {
    var wrap = item.querySelector('.cc-img-wrap');
    var img  = item.querySelector('.cc-img');
    if (!wrap || !img) return;

    /* Base scale comes from the block's image_scale setting (default 100 = 1×) */
    var baseScale = (parseFloat(item.getAttribute('data-scale')) || 100) / 100;
    var scale     = baseScale;

    /* Sync inline transform with the CSS-defined base so there's no jump */
    img.style.transform  = 'scale(' + baseScale + ')';
    img.style.transition = 'transform 0.12s ease-out';

    wrap.addEventListener('wheel', function (e) {
      e.preventDefault();
      e.stopPropagation();

      var delta = e.deltaY < 0 ? 0.1 : -0.1;
      scale = +(Math.min(Math.max(scale + delta, 0.5), 3.0).toFixed(2));
      img.style.transform = 'scale(' + scale + ')';
      wrap.classList.toggle('cc-zoomed', scale > baseScale * 1.05);
    }, { passive: false });

    /* Double-click resets to the block-defined base scale */
    wrap.addEventListener('dblclick', function () {
      scale = baseScale;
      img.style.transform = 'scale(' + baseScale + ')';
      wrap.classList.remove('cc-zoomed');
    });
  });
})();
</script>

{% schema %}
{
  "name": "Category Carousel",
  "class": "cc-section-wrapper",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Alignment",
      "default": "center",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_width",
      "label": "Section Width",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "shape",
      "label": "Collection Shape",
      "default": "circle",
      "options": [
        { "value": "circle",  "label": "Circle"  },
        { "value": "square",  "label": "Square"  },
        { "value": "rounded", "label": "Rounded" }
      ]
    },
    {
      "type": "select",
